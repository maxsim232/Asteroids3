<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.text.Font?>
<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.asteroids.HelloController">
    <ImageView fx:id="bg1" fitWidth="900" fitHeight="600"/>
    <ImageView fx:id="bg2" fitWidth="900" fitHeight="600"/>
<Group fx:id="groupRocket" >
    <ImageView fx:id="rocket" rotate="90"  fitWidth="60" fitHeight="90" layoutX="100" layoutY="285"/>
    <ImageView fx:id="flame" rotate="-90"  fitWidth="20" fitHeight="30" layoutX="80" layoutY="310"/>
</Group>
    <ImageView fx:id="asteroid1" rotate="90" fitWidth="90" fitHeight="60" />
    <ImageView fx:id="asteroid2"   rotate="85 " fitWidth="90" fitHeight="60" />
    <ImageView fx:id="asteroid3" rotate="45" fitWidth="90" fitHeight="60" />
    <Label fx:id="lblGameOver" layoutX="300.0" layoutY="200.0" text="Game Over" textFill="#fffb15">
        <font>
            <Font size="72.0" />
        </font>
    </Label>


</AnchorPane>
